{
  "name": "@hugg/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@hugg/schemas": "workspace:*",
    "@hugg/types": "workspace:*",
    "@hugg/utils": "workspace:*",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "prisma": "^7.0.0",
    "dotenv": "^16.0.0",
    "better-auth": "^1.0.0",
    "bullmq": "^5.8.0",
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/websocket": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@hugg/config": "workspace:*",
    "@types/node": "^20.0.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0"
  }
}
