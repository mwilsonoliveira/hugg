generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  phone         String?
  avatarUrl     String?
  emailVerified Boolean  @default(false)
  googleId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pets      Pet[]
  adoptions Adoption[]
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Pet {
  id           String    @id @default(cuid())
  name         String?
  species      Species
  breed        String?
  age          Int?
  description  String?
  imageUrls    String[]
  gender       Gender?
  status       PetStatus  @default(AVAILABLE)
  situation    Situation  @default(SHELTER)
  waitingSince DateTime   @default(now())
  latitude     Float?
  longitude    Float?
  locationNote  String?
  locationPhone String?
  createdAt     DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  adoptions   Adoption[]
}

model SearchHistory {
  id        String   @id @default(cuid())
  query     String
  count     Int      @default(1)
  lastUsed  DateTime @default(now())

  @@unique([query])
}

model Adoption {
  id        String         @id @default(cuid())
  status    AdoptionStatus @default(PENDING)
  message   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  petId  String
  pet    Pet    @relation(fields: [petId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
}

enum Gender {
  MALE
  FEMALE
}

enum Situation {
  SHELTER
  ABANDONED
  FOSTER
  STREET
}

enum Species {
  DOG
  CAT
  BIRD
  RABBIT
  OTHER
}

enum PetStatus {
  AVAILABLE
  UNDER_REVIEW
  ADOPTED
}

enum AdoptionStatus {
  PENDING
  APPROVED
  REJECTED
}
